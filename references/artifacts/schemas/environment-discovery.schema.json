{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Environment Discovery",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "contract": {
      "type": "string",
      "const": "environment_discovery"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "environment_summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "package_managers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "framework_hints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "available_runtimes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_access_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "package_managers",
        "framework_hints",
        "available_runtimes",
        "source_access_patterns"
      ]
    },
    "discovered_surfaces": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dependency_files": {
          "type": "array"
        },
        "training_surfaces": {
          "type": "array"
        },
        "serving_surfaces": {
          "type": "array"
        },
        "dataset_surfaces": {
          "type": "array"
        },
        "evaluation_surfaces": {
          "type": "array"
        }
      },
      "required": [
        "dependency_files",
        "training_surfaces",
        "serving_surfaces",
        "dataset_surfaces",
        "evaluation_surfaces"
      ]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unresolved_gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "contract",
    "schema_version",
    "workspace_root",
    "environment_summary",
    "discovered_surfaces",
    "constraints",
    "unresolved_gaps",
    "notes"
  ]
}
