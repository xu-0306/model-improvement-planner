{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Probe Result",
  "description": "Schema-light contract for one normalized baseline probe outcome.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "contract": {
      "type": "string",
      "const": "probe_result"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "probe_id": {
      "type": "string",
      "minLength": 1
    },
    "probe_family": {
      "type": "string",
      "minLength": 1
    },
    "expected_evaluation_mode": {
      "type": "string"
    },
    "target_capability": {
      "type": "string"
    },
    "target_language": {
      "type": "string"
    },
    "rubric_reference": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "response_status": {
      "type": "string",
      "minLength": 1
    },
    "raw_metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "teacher_verdict": {
      "type": "object",
      "additionalProperties": true
    },
    "evaluator_id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "response_language_hint": {
      "type": "string"
    },
    "model_profile_reference": {
      "type": "string"
    },
    "score": {
      "type": "number"
    },
    "passed": {
      "type": "boolean"
    }
  },
  "required": [
    "contract",
    "schema_version",
    "probe_id",
    "probe_family",
    "input",
    "expected_evaluation_mode",
    "target_capability",
    "target_language",
    "rubric_reference",
    "tags",
    "metadata",
    "response_status",
    "student_response",
    "raw_metrics",
    "teacher_verdict",
    "evaluator_id",
    "notes",
    "response_language_hint"
  ]
}
