{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runtime Scaffold Manifest",
  "description": "Schema-light manifest for externally generated runtime scaffolds.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "contract": {
      "type": "string",
      "const": "runtime_scaffold_manifest"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "runtime_id": {
      "type": "string",
      "minLength": 1
    },
    "model_family": {
      "type": "string"
    },
    "supported_checkpoint_formats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supported_tokenizer_formats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inference_loading_strategy": {
      "type": "string"
    },
    "training_support_status": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unresolved_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    }
  },
  "required": [
    "contract",
    "schema_version",
    "runtime_id",
    "model_family",
    "supported_checkpoint_formats",
    "supported_tokenizer_formats",
    "inference_loading_strategy",
    "training_support_status",
    "assumptions",
    "unresolved_gaps",
    "status"
  ]
}
