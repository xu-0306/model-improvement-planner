{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Intervention Decision",
  "description": "Schema-light contract for bounded intervention decisions produced after capability routing.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "contract": {
      "type": "string",
      "const": "intervention_decision"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "target_capability": {
      "type": "string",
      "minLength": 1
    },
    "problem_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chosen_intervention_family": {
      "type": "string",
      "minLength": 1
    },
    "implementation_direction": {
      "type": "string",
      "minLength": 1
    },
    "decision_status": {
      "type": "string",
      "minLength": 1
    },
    "decision_summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_basis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected_alternatives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "key_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stop_or_continue_reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "contract",
    "schema_version",
    "target_capability",
    "problem_types",
    "chosen_intervention_family",
    "implementation_direction",
    "decision_status",
    "decision_summary",
    "evidence_basis",
    "rejected_alternatives",
    "key_risks",
    "next_actions",
    "stop_or_continue_reason"
  ]
}
