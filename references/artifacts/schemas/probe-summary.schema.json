{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Probe Summary",
  "description": "Schema-light contract for aggregated baseline probe evidence.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "contract": {
      "type": "string",
      "const": "probe_summary"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "total_probes": {
      "type": "number",
      "minimum": 0
    },
    "answered_probes": {
      "type": "number",
      "minimum": 0
    },
    "missing_responses": {
      "type": "number",
      "minimum": 0
    },
    "families": {
      "type": "object",
      "additionalProperties": true
    },
    "response_statuses": {
      "type": "object",
      "additionalProperties": true
    },
    "expected_evaluation_modes": {
      "type": "object",
      "additionalProperties": true
    },
    "target_languages": {
      "type": "object",
      "additionalProperties": true
    },
    "response_languages": {
      "type": "object",
      "additionalProperties": true
    },
    "family_diagnostics": {
      "type": "object",
      "additionalProperties": true
    },
    "model_profile_reference": {
      "type": "string"
    },
    "average_score": {
      "type": "number"
    },
    "pass_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_signatures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suspected_bottlenecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_teacher_roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_supervision_shapes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "route_readiness": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "contract",
    "schema_version",
    "total_probes",
    "answered_probes",
    "missing_responses",
    "families",
    "response_statuses",
    "expected_evaluation_modes",
    "target_languages",
    "response_languages",
    "family_diagnostics",
    "strengths",
    "weaknesses",
    "failure_signatures",
    "suspected_bottlenecks",
    "recommended_teacher_roles",
    "recommended_supervision_shapes",
    "route_readiness"
  ]
}
