{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capability Intake Artifact",
  "description": "Schema-light contract for normalized capability intake artifacts used before route selection.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "contract": {
      "type": "string",
      "const": "capability_intake"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "requested_capability": {
      "type": "string",
      "minLength": 1
    },
    "desired_outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deployment_context": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "user_intent": {
      "type": "string",
      "minLength": 1
    },
    "input_modalities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_modalities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "sub_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "external_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "contract",
    "schema_version",
    "requested_capability",
    "desired_outcomes",
    "failure_modes",
    "success_criteria",
    "deployment_context",
    "user_intent",
    "input_modalities",
    "output_modalities",
    "constraints",
    "sub_capabilities",
    "external_dependencies",
    "missing_facts"
  ]
}
